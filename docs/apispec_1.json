{
  "definitions": {},
  "info": {
    "description": "A RESTful API for researchers to track arXiv papers, manage research notes, and use spaced repetition learning.",
    "termsOfService": "",
    "title": "ScholarTrack API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/auth/login": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "password": {
                  "example": "securepass123",
                  "type": "string"
                },
                "username": {
                  "example": "researcher1",
                  "type": "string"
                }
              },
              "required": [
                "username",
                "password"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Login successful",
            "schema": {
              "properties": {
                "data": {
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "expires_in": {
                      "example": 86400,
                      "type": "integer"
                    },
                    "token_type": {
                      "example": "bearer",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "401": {
            "description": "Invalid username or password"
          }
        },
        "summary": "Authenticate user and obtain JWT token.",
        "tags": [
          "Authentication"
        ]
      }
    },
    "/api/auth/register": {
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "email": {
                  "example": "researcher1@example.com",
                  "type": "string"
                },
                "password": {
                  "example": "securepass123",
                  "type": "string"
                },
                "username": {
                  "example": "researcher1",
                  "type": "string"
                }
              },
              "required": [
                "username",
                "email",
                "password"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "User registered successfully",
            "schema": {
              "properties": {
                "_links": {
                  "properties": {
                    "login": {
                      "type": "string"
                    },
                    "self": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "data": {
                  "properties": {
                    "created_at": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "id": {
                      "type": "integer"
                    },
                    "preferred_categories": {
                      "items": {
                        "type": "string"
                      },
                      "type": "array"
                    },
                    "username": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "400": {
            "description": "Missing required fields or invalid email format"
          },
          "409": {
            "description": "Username or email already exists"
          }
        },
        "summary": "Register a new user account.",
        "tags": [
          "Authentication"
        ]
      }
    },
    "/api/flashcards": {
      "get": {
        "parameters": [
          {
            "description": "Filter by note ID",
            "in": "query",
            "name": "note_id",
            "required": false,
            "type": "integer"
          },
          {
            "default": 1,
            "in": "query",
            "name": "page",
            "type": "integer"
          },
          {
            "default": 20,
            "in": "query",
            "name": "per_page",
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of flashcards"
          },
          "401": {
            "description": "Missing or invalid JWT token"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "List all flashcards for the current user.",
        "tags": [
          "Flashcards"
        ]
      },
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "answer": {
                  "example": "A mechanism that runs multiple attention functions in parallel.",
                  "type": "string"
                },
                "note_id": {
                  "example": 1,
                  "type": "integer"
                },
                "question": {
                  "example": "What is Multi-Head Attention?",
                  "type": "string"
                }
              },
              "required": [
                "note_id",
                "question",
                "answer"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Flashcard created successfully"
          },
          "400": {
            "description": "Missing required fields"
          },
          "401": {
            "description": "Missing or invalid JWT token"
          },
          "403": {
            "description": "Note does not belong to current user"
          },
          "404": {
            "description": "Note not found"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Create a new flashcard linked to a note.",
        "tags": [
          "Flashcards"
        ]
      }
    },
    "/api/flashcards/due": {
      "get": {
        "responses": {
          "200": {
            "description": "List of due flashcards with total count",
            "schema": {
              "properties": {
                "data": {
                  "items": {
                    "type": "object"
                  },
                  "type": "array"
                },
                "total_due": {
                  "type": "integer"
                }
              },
              "type": "object"
            }
          },
          "401": {
            "description": "Missing or invalid JWT token"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Get flashcards due for review today.",
        "tags": [
          "Spaced Repetition"
        ]
      }
    },
    "/api/flashcards/{card_id}": {
      "delete": {
        "parameters": [
          {
            "description": "Flashcard ID",
            "in": "path",
            "name": "card_id",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "204": {
            "description": "Flashcard deleted successfully"
          },
          "401": {
            "description": "Missing or invalid JWT token"
          },
          "403": {
            "description": "Flashcard does not belong to current user"
          },
          "404": {
            "description": "Flashcard not found"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Delete a flashcard.",
        "tags": [
          "Flashcards"
        ]
      },
      "put": {
        "parameters": [
          {
            "description": "Flashcard ID",
            "in": "path",
            "name": "card_id",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "answer": {
                  "example": "Updated answer.",
                  "type": "string"
                },
                "question": {
                  "example": "Updated question?",
                  "type": "string"
                }
              },
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Flashcard updated successfully"
          },
          "400": {
            "description": "Request body is required"
          },
          "401": {
            "description": "Missing or invalid JWT token"
          },
          "403": {
            "description": "Flashcard does not belong to current user"
          },
          "404": {
            "description": "Flashcard not found"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Update a flashcard's question or answer.",
        "tags": [
          "Flashcards"
        ]
      }
    },
    "/api/flashcards/{card_id}/review": {
      "post": {
        "parameters": [
          {
            "description": "Flashcard ID",
            "in": "path",
            "name": "card_id",
            "required": true,
            "type": "integer"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "rating": {
                  "description": "SM-2 rating: 0=forgot completely, 5=perfect recall",
                  "example": 4,
                  "maximum": 5,
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "required": [
                "rating"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Review recorded, returns updated SM-2 parameters",
            "schema": {
              "properties": {
                "data": {
                  "properties": {
                    "flashcard_id": {
                      "type": "integer"
                    },
                    "rating": {
                      "type": "integer"
                    },
                    "reviewed_at": {
                      "type": "string"
                    },
                    "updated": {
                      "properties": {
                        "ease_factor": {
                          "type": "number"
                        },
                        "interval": {
                          "type": "integer"
                        },
                        "next_review_at": {
                          "type": "string"
                        },
                        "repetitions": {
                          "type": "integer"
                        }
                      },
                      "type": "object"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "400": {
            "description": "Rating must be an integer between 0 and 5"
          },
          "401": {
            "description": "Missing or invalid JWT token"
          },
          "403": {
            "description": "Flashcard does not belong to current user"
          },
          "404": {
            "description": "Flashcard not found"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Submit a review rating for a flashcard (SM-2 spaced repetition).",
        "tags": [
          "Spaced Repetition"
        ]
      }
    },
    "/api/library": {
      "get": {
        "parameters": [
          {
            "description": "Filter by tag name",
            "example": "deep-learning",
            "in": "query",
            "name": "tag",
            "required": false,
            "type": "string"
          },
          {
            "default": 1,
            "description": "Page number",
            "in": "query",
            "name": "page",
            "required": false,
            "type": "integer"
          },
          {
            "default": 20,
            "description": "Results per page (max 100)",
            "in": "query",
            "name": "per_page",
            "required": false,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of saved papers"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "List all papers in the user's library.",
        "tags": [
          "Paper Management"
        ]
      }
    },
    "/api/library/{arxiv_id}/tags": {
      "post": {
        "parameters": [
          {
            "description": "The arXiv paper identifier",
            "example": "2301.07041",
            "in": "path",
            "name": "arxiv_id",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "tags": {
                  "example": [
                    "deep-learning",
                    "transformers"
                  ],
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "required": [
                "tags"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated list of tags on the paper"
          },
          "400": {
            "description": "Invalid request body or tags not a list"
          },
          "404": {
            "description": "Paper not found or not in library"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Add tags to a saved paper.",
        "tags": [
          "Paper Management"
        ]
      }
    },
    "/api/library/{arxiv_id}/tags/{tag_name}": {
      "delete": {
        "parameters": [
          {
            "description": "The arXiv paper identifier",
            "example": "2301.07041",
            "in": "path",
            "name": "arxiv_id",
            "required": true,
            "type": "string"
          },
          {
            "description": "Name of the tag to remove",
            "example": "deep-learning",
            "in": "path",
            "name": "tag_name",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Tag removed from paper"
          },
          "404": {
            "description": "Paper, library entry, or tag not found"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Remove a tag from a saved paper.",
        "tags": [
          "Paper Management"
        ]
      }
    },
    "/api/notes": {
      "get": {
        "parameters": [
          {
            "description": "Filter by arXiv paper ID",
            "example": "2301.07041",
            "in": "query",
            "name": "paper_id",
            "required": false,
            "type": "string"
          },
          {
            "default": 1,
            "description": "Page number",
            "in": "query",
            "name": "page",
            "required": false,
            "type": "integer"
          },
          {
            "default": 20,
            "description": "Results per page (max 100)",
            "in": "query",
            "name": "per_page",
            "required": false,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of notes"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "List all notes for the authenticated user.",
        "tags": [
          "Notes"
        ]
      },
      "post": {
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "properties": {
                "content": {
                  "example": "The paper demonstrates that multi-head attention can be pruned without significant performance loss.",
                  "type": "string"
                },
                "paper_id": {
                  "description": "arXiv ID to link the note to a paper",
                  "example": "2301.07041",
                  "type": "string"
                },
                "title": {
                  "example": "Key findings on attention mechanisms",
                  "type": "string"
                }
              },
              "required": [
                "title",
                "content"
              ],
              "type": "object"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Note created successfully"
          },
          "400": {
            "description": "Missing required fields"
          },
          "404": {
            "description": "Linked paper not found"
          }
        },
        "security": [
          {
            "Bearer": []
          }
        ],
        "summary": "Create a new research note.",
        "tags": [
          "Notes"
        ]
      }
    },
