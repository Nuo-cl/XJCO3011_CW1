    "/api/papers/search": {
      "get": {
        "parameters": [
          {
            "description": "Search query string",
            "example": "transformer attention mechanism",
            "in": "query",
            "name": "q",
            "required": true,
            "type": "string"
          },
          {
            "description": "arXiv category filter",
            "example": "cs.AI",
            "in": "query",
            "name": "category",
            "required": false,
            "type": "string"
          },
          {
            "description": "Start date filter (YYYY-MM-DD)",
            "example": "2025-01-01",
            "in": "query",
            "name": "date_from",
            "required": false,
            "type": "string"
          },
          {
            "description": "End date filter (YYYY-MM-DD)",
            "example": "2025-12-31",
            "in": "query",
            "name": "date_to",
            "required": false,
            "type": "string"
          },
          {
            "default": 1,
            "description": "Page number",
            "in": "query",
            "name": "page",
            "required": false,
            "type": "integer"
          },
          {
            "default": 20,
            "description": "Results per page (max 100)",
            "in": "query",
            "name": "per_page",
            "required": false,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "List of matching papers with pagination"
          },
          "400": {
            "description": "Missing required query parameter \"q\""
          }
        },
        "summary": "Search for papers on arXiv.",
        "tags": [
          "Paper Discovery"
        ]
      }
    },
    "/api/papers/trending": {
      "get": {
        "parameters": [
          {
            "description": "arXiv category",
